{
  "name": "codex-canvas",
  "version": "0.1.1",
  "description": "Local infinite canvas plugin for Codex image workflows.",
  "type": "module",
  "bin": {
    "codex-canvas": "./bin/codex-canvas.mjs"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "AGENTS.md",
    "README.md",
    "assets/",
    "bin/",
    "docs/",
    "public/",
    "scripts/",
    "skills/",
    "src/"
  ],
  "scripts": {
    "setup:ocr": "node ./bin/codex-canvas.mjs setup-ocr",
    "setup:image-deps": "node ./bin/codex-canvas.mjs setup-image-deps",
    "setup:deps": "node ./bin/codex-canvas.mjs setup-deps",
    "install:personal": "node ./scripts/install-personal-plugin.mjs",
    "install:dev-cache": "node ./scripts/link-dev-plugin-cache.mjs",
    "doctor:ocr": "node ./bin/codex-canvas.mjs doctor-ocr --json",
    "doctor:image-deps": "node ./bin/codex-canvas.mjs doctor-image-deps --json",
    "doctor:deps": "node ./bin/codex-canvas.mjs doctor-deps --json",
    "start": "node ./bin/codex-canvas.mjs start",
    "validate": "node ./bin/codex-canvas.mjs status --json",
    "smoke": "node ./scripts/smoke.mjs",
    "smoke:visual": "node ./scripts/visual-smoke.mjs",
    "visual:regression": "node ./scripts/visual-regression.mjs",
    "test": "npm run smoke"
  },
  "keywords": [
    "codex",
    "plugin",
    "canvas",
    "imagegen"
  ],
  "author": {
    "name": "Codex-Canvas Contributors"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "ag-psd": "^31.0.0",
    "pngjs": "^7.0.0"
  }
}
