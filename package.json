{
  "name": "agent-canvas",
  "version": "0.1.1",
  "description": "Local infinite canvas plugin for Codex image workflows.",
  "type": "module",
  "bin": {
    "agent-canvas": "./bin/agent-canvas.mjs"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "AGENTS.md",
    "README.md",
    "assets/",
    "bin/",
    "docs/",
    "public/",
    "scripts/",
    "skills/",
    "src/"
  ],
  "scripts": {
    "setup:ocr": "node ./bin/agent-canvas.mjs setup-ocr",
    "setup:image-deps": "node ./bin/agent-canvas.mjs setup-image-deps",
    "setup:deps": "node ./bin/agent-canvas.mjs setup-deps",
    "doctor:ocr": "node ./bin/agent-canvas.mjs doctor-ocr --json",
    "doctor:image-deps": "node ./bin/agent-canvas.mjs doctor-image-deps --json",
    "doctor:deps": "node ./bin/agent-canvas.mjs doctor-deps --json",
    "start": "node ./bin/agent-canvas.mjs start",
    "validate": "node ./bin/agent-canvas.mjs status --json",
    "smoke": "node ./scripts/smoke.mjs",
    "test": "npm run smoke"
  },
  "keywords": [
    "codex",
    "plugin",
    "canvas",
    "imagegen"
  ],
  "author": {
    "name": "Agent-Canvas Contributors"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  }
}
